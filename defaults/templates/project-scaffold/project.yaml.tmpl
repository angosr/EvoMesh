# EvoMesh project config
# Generated by Central AI or smartInit()
name: {project_name}
created: {created_date}
repo: "{repo_url}"
lang: {lang}

# Claude account mapping
# key = alias, value = config directory path
# Use different accounts for lead vs executor to avoid rate limits
accounts:
  default: {default_account}

# Role definitions
# Each role runs in a Docker container (or host tmux if launch_mode: host)
roles:
  lead:
    type: lead
    loop_interval: 20m
    account: default
    evolution_upgrade_every: 30
    scope:
      - .evomesh/blueprint.md
      - .evomesh/status.md
      - .evomesh/roles/*/inbox/
      - docs/
    description: "Project director — strategy, docs, role coordination"
  executor:
    type: worker
    loop_interval: 10m
    account: default
    scope:
      - src/
      - tests/
    description: "Code executor — feature development, testing, commits"

git:
  branch: main
  conflict_resolution: auto
  auto_push: true
